library(leaflet) # carte interactive
library(dplyr)
library(sf) # pour les shape
# import du jeu de donnees DI global
di_global <-st_read("06_Prio_Volcan_2026_v3.shp")
# verification import
class(di_global)
plot(di_global)
# leaflet = WGS 84
# on transforme car on est en UTM40S
di_global <- st_transform(di_global, 4326)
#verification
st_crs(di_global)
# reordonne la légende avant tout
di_global$DI_6cat <- factor(
di_global$DI_6cat,
levels = c(
"intact",
"peu envahi (1)",
"peu envahi (2)",
"moyennement envahi (3)",
"moyennement envahi (4)",
"très envahi (5)",
"très envahi (6)"))
pal <- colorFactor(palette = c(
"intact" = "#00994C",
"peu envahi (1)" = "#73C754",
"peu envahi (2)" = "#C1DEB6",
"moyennement envahi (3)" = "#FFF558",
"moyennement envahi (4)" = "#FF8000",
"très envahi (5)" = "#E95427",
"très envahi (6)" = "#B52D04"
), domain = di_global$DI_6cat)
leaflet(di_global) %>%
addProviderTiles(providers$OpenTopoMap) |> # fond satellite
#addTiles() %>%
addPolygons(
fillColor = ~pal(DI_6cat),
color = "black",
weight = 0.6,
fillOpacity = 0.7,
popup = ~paste0(
"<strong>Catégorie :</strong> ", DI_6cat, "<br>")
) %>%
addLegend(
"bottomright",
pal = pal,
values = ~DI_6cat,
title = "DI",
opacity = 1
)
leaflet(di_global) %>%
addProviderTiles(providers$OpenTopoMap) |> # fond satellite
#addTiles() %>%
addPolygons(
fillColor = ~pal(DI_6cat),
color = "black",
weight = 0.6,
fillOpacity = 0.4,
popup = ~paste0(
"<strong>Catégorie :</strong> ", DI_6cat, "<br>")
) %>%
addLegend(
"bottomright",
pal = pal,
values = ~DI_6cat,
title = "DI",
opacity = 1
)
View(di_global)
breaks <- seq(0, 100, by = 6.7)
di_global$classe <- cut(
di_global$enjeux_Z,
breaks = breaks,
include.lowest = TRUE
)
View(di_global)
breaks <- c(  0, 6.7, 13.3, 19.9, 26.6, 33.2, 39.9, 46.5, 53.2, 59.8, 66.4, 73.1, 79.7, 86.4, 93, 99.7)
di_global$classe <- cut(
di_global$enjeux_Z,
breaks = breaks,
include.lowest = TRUE)
di_global$classe <- cut(
di_global$enjeux_Z,
breaks = breaks,
labels = labels,
include.lowest = TRUE,
right = FALSE
)
labels <- paste0( "[",  head(breaks, -1), " - ",  tail(breaks, -1), "]")
di_global$classe <- cut(
di_global$enjeux_Z,
breaks = breaks,
labels = labels,
include.lowest = TRUE,
right = FALSE
)
View(di_global)
names(classes)
names(classe)
di_global$classe
library(leaflet) # carte interactive
library(dplyr)
library(sf) # pour les shape
# import du jeu de donnees DI global
di_global <-st_read("06_Prio_Volcan_2026_v3.shp")
# verification import
class(di_global)
plot(di_global)
# leaflet = WGS 84
# on transforme car on est en UTM40S
di_global <- st_transform(di_global, 4326)
#verification
st_crs(di_global)
breaks <- c(  0, 6.7, 13.3, 19.9, 26.6, 33.2, 39.9, 46.5, 53.2, 59.8, 66.4, 73.1, 79.7, 86.4, 93, 99.7)
labels <- paste0( "[",  head(breaks, -1), " - ",  tail(breaks, -1), "]")
di_global$classe <- cut(
di_global$enjeux_Z,
breaks = breaks,
labels = labels,
include.lowest = TRUE,
right = FALSE
)
pal <- colorFactor(palette = c(
"[0 - 6.7]" = "#F7FCF5",
"[6.7 - 13.3]" = "#EDF8E9",
"[13.3 - 19.9]" = "#E2F4DD",
"[19.9 - 26.6]" = "#D2EDCB",
"[26.6 - 33.2]" = "#BFE6B9",
"[33.2 - 39.9]" = "#ABDDA4",
"[39.9 - 46.5]" = "#94D390",
"[46.5 - 53.2]" = "#7BC77C",
"[53.2 - 59.8]" = "#60BA6C",
"[59.8 - 66.4]" = "#44AC5E",
"[66.4 - 73.1]" = "#329B51",
"[73.1 - 79.7]" = "#218A44",
"[79.7 - 86.4]" = "#0D7835",
"[86.4 - 93]" = "#006217",
"[93 - 99.7]" = "#00441B"
), domain = di_global$enjeux_Z)
leaflet(di_global) %>%
addProviderTiles(providers$OpenTopoMap) |> # fond satellite
#addTiles() %>%
addPolygons(
fillColor = ~pal(enjeux_Z),
color = "black",
weight = 0.6,
fillOpacity = 0.6,
popup = ~paste0(
"<strong>Catégorie :</strong> ", enjeux_Z, "<br>")
) %>%
addLegend(
"bottomright",
pal = pal,
values = ~enjeux_Z,
title = "Enjeux",
opacity = 1
)
leaflet(di_global) %>%
addProviderTiles(providers$OpenTopoMap) |> # fond satellite
